<form class="sheet actor-sheet book-tabs-layout {{cssClass}}" autocomplete="off" data-actor-id="{{actor.id}}">
  <div class="jojo-sheet">
    {{> actor-effects}}
    <section class="sheet-body">
      <!-- ─────────────────────── Stats Tab ─────────────────────── -->
      <div class="tab" data-tab="stats" data-group="primary">
        <div class="actor-main-array actor-main-array--split">
          <section class="user-panel actor-panel actor-panel--basic-info">
            <div class="basic-actor-name">
              <span class="name-display">{{actor.name}}</span>
              <input class="name-edit" value="{{actor.name}}" style="display:none;" />
            </div>
            <div class="basic-image-wrap">
              <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
            </div>
            <canvas class="actor-stat-chart actor-stat-chart--inline" data-stat-chart width="260" height="260"></canvas>
          </section>

          <section class="user-panel actor-panel actor-panel--stats-values">
            <h3>Stats</h3>
            {{> actor-stats}}
          </section>

          <section class="user-panel actor-panel actor-panel--bio">
            
            <div class="bio-summary core-info-container">
              <div class="bio-description-grid {{#unless hasBioProperty}}bio-description-grid--single{{/unless}}">
                {{#if hasBioProperty}}
                  <div class="bio-description-card bio-description-card--property">
                    <h4>{{bioPropertyLabel}}</h4>
                    <div class="bio-description-value">{{bioPropertyValue}}</div>
                  </div>
                {{/if}}

                <div class="bio-description-card bio-description-card--ability {{#unless hasBioProperty}}bio-description-card--full{{/unless}}">
                  <h4>Ability Description</h4>
                  <div class="bio-description-value">{{{bioAbilityDescription}}}</div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>

      <!-- ───────────────────── Power Info Tab ───────────────────── -->
      <div class="tab" data-tab="info" data-group="primary">
        <div class="actor-tab-panel">
          <section class="user-panel actor-panel actor-panel--info">
        <div class="info-container">
          <div class="info-row">
            <label>Name:</label>
            <input
              type="text"
              name="system.bio.powerName"
              value="{{system.bio.powerName}}"
              placeholder="Enter power name"
            />
          </div>
          <div class="info-row" data-drop="ability">
            <label>Master:</label>
            {{#each linkedActors as |linked|}}
                <div class="linked-ability" data-uuid="{{linked.uuid}}">
                    <span>{{linked.name}} ({{linked.type}})</span>
                    <a class="remove-link" data-uuid="{{linked.uuid}}">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            {{else}}
                <p class="hint">Drag a user here to link a master</p>
            {{/each}}
          </div>
          <div class="info-row">
            <label>Design:</label>
            <textarea
              name="system.bio.design"
              rows="3"
              placeholder="Enter design"
            >{{system.bio.design}}</textarea>
          </div>
          <div class="info-row">
            <label>Type:</label>
            <select id="power-type" name="system.bio.type">
              {{#each typeConfigs}}
                <option value="{{@key}}" {{#ifEquals system.bio.type @key}}selected{{/ifEquals}}>
                  {{this.label}}
                </option>
              {{/each}}
            </select>
          </div>
          {{> actor-class}}
          {{#if typeDescriptionHtml}}
          <div class="info-row info-row--default-description">
            <label>Description:</label>
            <div class="info-default-description">{{{typeDescriptionHtml}}}</div>
          </div>
          {{/if}}
        </div>
          </section>
        </div>
      </div>
      <!-- ─────────────────────── Ability Description Tab ─────────────────────── -->
      <div class="tab" data-tab="{{actor.system.bio.type}}" data-group="primary">
        <div class="actor-tab-panel">
          <section class="user-panel actor-panel actor-panel--ability">
            <div class="ability-description">
              {{{bioAbilityDescription}}}
            </div>
          </section>
        </div>
      </div>
    </section>
  </div>

  <nav class="sheet-tabs tabs" data-group="primary">
    {{> actor-nav}}
  </nav>
</form>
