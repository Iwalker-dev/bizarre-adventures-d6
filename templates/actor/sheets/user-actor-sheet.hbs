{{!-- systems/bizarre-adventures-d6/templates/sheets/user-actor-sheet.hbs --}}
<form class="sheet actor-sheet book-tabs-layout {{cssClass}}" autocomplete="off" data-actor-id="{{actor.id}}">
  <div class="jojo-sheet">
    {{> actor-effects}}
    <section class="sheet-body">
      <!-- ─ Stats Tab ─ -->
      <div class="tab"
        data-tab="stats"
        data-group="primary">
        <div class="user-main-array {{#unless activeFormulaModifiers.length}}no-mods{{/unless}}">
          <section class="user-panel user-panel--basic-info">
            <div class="basic-actor-name">
              <span class="name-display">{{actor.name}}</span>
              <input class="name-edit" value="{{actor.name}}" style="display:none;" />
            </div>
            <div class="basic-image-wrap">
              <img src="{{actor.img}}" title="{{actor.name}}" />
              <div class="basic-health-chip">
                HP {{system.health.value}} / {{system.health.max}}
              </div>
              {{#if (lte system.health.value 0)}}
                <button type="button"
                        class="dark-determination-toggle basic-dd-toggle"
                        aria-pressed="{{#if darkDetermination}}true{{else}}false{{/if}}"
                        title="Toggle Dark Determination">
                  <i class="fas fa-fire {{#if darkDetermination}}pulse-dd-icon{{else}}static-dd-icon{{/if}}"></i>
                </button>
              {{/if}}
            </div>
            <canvas class="actor-stat-chart actor-stat-chart--inline" data-stat-chart width="260" height="260"></canvas>
          </section>

          {{#if activeFormulaModifiers.length}}
          <section class="user-panel user-panel--modifiers">
            <h3>Formula Modifiers</h3>
            <div class="modifier-list">
              {{#each activeFormulaModifiers as |modifier|}}
                <div class="modifier-row">
                  <span class="modifier-item">{{modifier.itemName}}</span>
                  <span class="modifier-detail">{{modifier.statLabel}} • {{modifier.variable}} {{modifier.operand}} {{modifier.value}}{{#if modifier.optional}} • Optional{{/if}}</span>
                </div>
              {{/each}}
            </div>
          </section>
          {{/if}}

          <section class="user-panel user-panel--stats">
            <h3>Stats</h3>
            {{> actor-stats}}
          </section>

          <section class="user-panel user-panel--inventory">
            <h3>Hits & Items</h3>
            <div class="overview-columns">
              <div>
                <h4>Hits</h4>
                <ul>
                  {{#each actor.items}}
                    {{#if (eq this.type "hit")}}
                      <li>{{this.name}} ({{this.system.quantity}})</li>
                    {{/if}}
                  {{/each}}
                </ul>
              </div>
              <div>
                <h4>Items</h4>
                <ul>
                  {{#each actor.items}}
                    {{#if (eq this.type "item")}}
                      <li>{{this.name}}</li>
                    {{/if}}
                  {{/each}}
                </ul>
              </div>
            </div>
          </section>
        </div>
      </div>

      <!-- ─ Biography Tab ─ -->
      <div class="tab"
        data-tab="info"
        data-group="primary">
        <div class="info-container">
          <div class="info-row">
            <label>Name:</label>
            <input type="text"
              name="system.bio.name"
              value="{{system.bio.name}}"
              placeholder="Enter name" />
          </div>
          <div class="info-row" data-drop="ability">
            <label>Abilities:</label>
            {{#each system.bio.linkedActors.value as |linked|}}
                <div class="linked-ability" data-uuid="{{linked.uuid}}">
                    <span>{{linked.name}} ({{linked.type}})</span>
                    <a class="remove-link" data-uuid="{{linked.uuid}}">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            {{else}}
                <p class="hint">Drag actors here to link abilities</p>
            {{/each}}
          </div>
          <div class="info-row">
            <label>Gender:</label>
            <input type="text"
              name="system.bio.gender"
              value="{{system.bio.gender}}"
              placeholder="Enter gender"
              />
          </div>
          <div class="info-row">
            <label>Date of Birth:</label>
            <input type="text"
              name="system.bio.dob"
              value="{{system.bio.dob}}"
              placeholder="Enter date of birth"
              />
          </div>
          <div class="info-row">
            <label>Hit Limit:</label>
            <input 
              type="number"
              name="system.health.max"
              min="0"
              value="{{system.health.max}}" />
          </div>
          <div class="info-row">
            <label>Type:</label>
            <select id="user-type" name="system.bio.type">
              {{#each typeConfigs}}
                <option value="{{@key}}"
                {{#ifEquals system.bio.type @key}}selected{{/ifEquals}}>
                  {{this.label}}
                </option>
              {{/each}}
            </select>
          </div>
          {{> actor-class}}
          <div class="info-row">
            <label>Appearance:</label>
            <textarea name="system.bio.appearance" rows="3" placeholder="Describe appearance">{{system.bio.appearance}}</textarea>
          </div>
          <div class="info-row">
            <label>Personality:</label>
            <textarea name="system.bio.personality" rows="3" placeholder="Describe personality">{{system.bio.personality}}</textarea>
          </div>
          <div class="info-row">
            <label>Life Philosophy:</label>
            <textarea name="system.bio.philosophy" rows="3" placeholder="Enter life philosophy">{{system.bio.philosophy}}</textarea>
          </div>
          <div class="info-row">
            <label>Backstory:</label>
            <textarea name="system.bio.backstory" rows="5" placeholder="Enter backstory">{{system.bio.backstory}}</textarea>
          </div>
        </div>
      </div>
      <!-- ───────────── Info Type Tab ───────────── -->
      <div class="tab" data-tab="{{actor.system.bio.type}}" data-group="primary">
        <div class="ability-description">
          {{{system.bio.description}}}
        </div>
      </div>
      <!-- ───────────── Hits Tab ───────────── -->
      <div class="tab" data-tab="hit" data-group="primary">
        <div class="hit-container">
          <div class="hit-form">
            <button id="create-hit" type="button" title="Create Hit">
              <i class="fa-solid fa-plus fa-fw" aria-hidden="true"></i>
            </button>
          </div>

          <div class="hit-list scrollable-list">
            <ul id="hit-items">
              {{#each actor.items}}
                {{#if (eq this.type "hit")}}
                  <li data-item-id="{{this.id}}">
                    <span>{{this.name}} - Weight: {{this.system.weight}}, Quantity: {{this.system.quantity}}</span>
                    <p class="item-description">{{this.system.description}}</p>
                    <i class="fas fa-trash delete-hit" data-item-id="{{this.id}}"></i>
                  </li>
                {{/if}}
              {{/each}}
            </ul>
          </div>
        </div>
      </div>

      <!-- ───────────── Items Tab ───────────── -->
      <div class="tab" data-tab="item" data-group="primary">
        <div class="item-container">
          <div class="item-form">
            <button id="create-item" type="button" title="Create Item">
              <i class="fa-solid fa-plus fa-fw" aria-hidden="true"></i>
            </button>
          </div>

          <div class="item-list scrollable-list">
            <ul id="item-items">
              {{#each actor.items}}
                {{#if (eq this.type "item")}}
                  <li data-item-id="{{this.id}}">
                    <span>{{this.name}}</span>
                    <p class="item-description">{{this.system.description}}</p>
                    <i class="fas fa-trash delete-item" data-item-id="{{this.id}}"></i>
                  </li>
                {{/if}}
              {{/each}}
            </ul>
          </div>
        </div>
      </div>
    </section>
  </div>

  <nav class="sheet-tabs tabs" data-group="primary">
    {{> actor-nav}}
  </nav>
</form>
