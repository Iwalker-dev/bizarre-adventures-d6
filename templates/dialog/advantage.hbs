<div class="advantage-selection">
    <label>Advantage (click to confirm):</label>
    <div class="advantage-options">
        <button type="button" class="advantage-option" data-advantage="0" aria-label="Set advantage to 0">0</button>
        <button type="button" class="advantage-option" data-advantage="1" aria-label="Set advantage to 1">1</button>
        <button type="button" class="advantage-option" data-advantage="2" aria-label="Set advantage to 2">2</button>
        <button type="button" class="advantage-option" data-advantage="3" aria-label="Set advantage to 3">3</button>
    </div>
</div>